{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Synonyms Map",
  "type": "object",
  "required": ["domain_id", "groups"],
  "properties": {
    "domain_id": {
      "type": "string"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonical", "synonyms"],
        "properties": {
          "canonical": {
            "type": "string"
          },
          "synonyms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
